# Ignore build outputs and dependencies for common static, React, and TypeScript projects

# Node modules
node_modules/

# log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build output
dist/
build/
out/
coverage/

# Vite static build
.vite/

# Static site generators
public/
.next/
.vercel/
.svelte-kit/
.hugo/
.cache/
temp/
tmp/

# React Native
.expo/

# TypeScript type output
*.tsbuildinfo

# Local env files
.env*
!.env.example

# IDE/editor settings
.vscode/
.idea/
.DS_Store
Thumbs.db

# Misc
*.local